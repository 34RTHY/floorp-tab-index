{
  "manifest_version": 3,
  "name": "Tab Index",
  "version": "1.0.0",
  "description": "Shows tab index numbers in each tab's title. Know exactly which tab Ctrl/Cmd+1-8 will jump to.",
  "permissions": ["tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "48": "icons/icon-48.png"
    }
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  }
}
